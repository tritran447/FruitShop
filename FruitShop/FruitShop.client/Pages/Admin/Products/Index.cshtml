@page
@model FruitShop.client.Pages.Admin.Products.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Product Management";
}

<div class="container" style="margin-top:280px">
  <h2>@ViewData["Title"]</h2>

  <!-- Create Button -->
  <p>
    <button class="btn btn-success mb-3"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
      <i class="bi bi-plus-lg"></i> Create New Product
    </button>
  </p>

  @if (!Model.PagedProducts.Any())
  {
    <div class="alert alert-info">No products found.</div>
  }
  else
  {
    <table class="table table-bordered table-striped align-middle">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Description</th>
          <th>Price</th>
          <th>Qty In Stock</th>
          <th>Category ID</th>
          <th>Image</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var p in Model.PagedProducts)
        {
          <tr>
            <td>@p.ProductId</td>
            <td>@p.ProductName</td>
            <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
              @p.Description
            </td>
            <td>@p.Price.ToString("C")</td>
            <td>@(p.QuantityInStock?.ToString() ?? "-")</td>
            <td>@(p.CategoryId?.ToString() ?? "-")</td>
            <td>
              @if (!string.IsNullOrEmpty(p.Image))
              {
                <img src="~/assets/images/product-fruit/@p.Image"
                     alt="@p.ProductName"
                     style="height:40px" />
              }
            </td>
             <td>
                  @if (p.Status == true)
                  {
                      <span class="badge bg-success">Active</span>
                  }
                  else
                  {
                      <span class="badge bg-secondary">Inactive</span>
                  }
            </td>
            <td>
              <button
                      data-bs-toggle="modal"
                      data-bs-target="#editModal"
                      data-id="@p.ProductId"
                      data-name="@p.ProductName"
                      data-desc="@p.Description"
                      data-price="@p.Price"
                      data-qty="@p.QuantityInStock"
                      data-cat="@p.CategoryId"
                      data-image="@p.Image"
                      data-status="@(p.Status == true ? "true" : "false")">
                <i class="bi bi-pencil-square"></i> Edit
              </button>
              <button
                      data-bs-toggle="modal"
                      data-bs-target="#deleteModal"
                      data-id="@p.ProductId"
                      data-name="@p.ProductName">
                <i class="bi bi-trash"></i> Delete
              </button>
            </td>
          </tr>
        }
      </tbody>
    </table>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
      <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
          <li class="page-item @(Model.PageIndex==1? "disabled":"")">
            <a class="page-link"
               href="?PageIndex=@(Model.PageIndex-1)&PageSize=@Model.PageSize">
              &laquo;
            </a>
          </li>
          @for (int i = 1; i <= Model.TotalPages; i++)
          {
            <li class="page-item @(i==Model.PageIndex? "active":"")">
              <a class="page-link" href="?PageIndex=@i&PageSize=@Model.PageSize">@i</a>
            </li>
          }
          <li class="page-item @(Model.PageIndex==Model.TotalPages? "disabled":"")">
            <a class="page-link"
               href="?PageIndex=@(Model.PageIndex+1)&PageSize=@Model.PageSize">
              &raquo;
            </a>
          </li>
        </ul>
      </nav>
    }
  }

    <!-- Create Modal -->
    <div class="modal fade" id="createModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <form method="post" asp-page-handler="Create" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="CreateProduct.ProductName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category ID</label>
                            <input asp-for="CreateProduct.CategoryId" type="number" class="form-control" />
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label">Description</label>
                            <textarea asp-for="CreateProduct.Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Price</label>
                            <input asp-for="CreateProduct.Price" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Quantity In Stock</label>
                            <input asp-for="CreateProduct.QuantityInStock" type="number" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select asp-for="CreateProduct.Status" class="form-select">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label">Image filename</label>
                            <input asp-for="CreateProduct.Image" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Create</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="editModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <form method="post" asp-page-handler="Edit" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditProduct.ProductId" id="edit-id" />
                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="EditProduct.ProductName" class="form-control" id="edit-name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category ID</label>
                            <input asp-for="EditProduct.CategoryId" type="number" class="form-control" id="edit-cat" />
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label">Description</label>
                            <textarea asp-for="EditProduct.Description" class="form-control" rows="2" id="edit-desc"></textarea>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Price</label>
                            <input asp-for="EditProduct.Price" type="number" step="0.01" class="form-control" id="edit-price" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Quantity In Stock</label>
                            <input asp-for="EditProduct.QuantityInStock" type="number" class="form-control" id="edit-qty" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select asp-for="EditProduct.Status" class="form-select" id="edit-status">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label">Image filename</label>
                            <input asp-for="EditProduct.Image" class="form-control" id="edit-image" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Delete" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="DeleteId" id="delete-id" />
                    <p>Are you sure you want to delete <strong id="delete-name"></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // populate CREATE form (clear)
        var createModal = document.getElementById('createModal');
        createModal.addEventListener('show.bs.modal', function () {
          document.querySelector('input[name="CreateProduct.ProductName"]').value = '';
          document.querySelector('textarea[name="CreateProduct.Description"]').value = '';
          document.querySelector('input[name="CreateProduct.Price"]').value       = '';
          document.querySelector('input[name="CreateProduct.QuantityInStock"]').value = '';
          document.querySelector('input[name="CreateProduct.CategoryId"]').value    = '';
          document.querySelector('select[name="CreateProduct.Status"]').value      = 'true';
          document.querySelector('input[name="CreateProduct.Image"]').value       = '';
        });

        // populate EDIT form
        var editModal = document.getElementById('editModal');
        editModal.addEventListener('show.bs.modal', function (e) {
          var b = e.relatedTarget;
          document.getElementById('edit-id').value      = b.dataset.id;
          document.getElementById('edit-name').value    = b.dataset.name;
          document.getElementById('edit-desc').value    = b.dataset.desc;
          document.getElementById('edit-price').value   = b.dataset.price;
          document.getElementById('edit-qty').value     = b.dataset.qty;
          document.getElementById('edit-cat').value     = b.dataset.cat;
          document.getElementById('edit-image').value   = b.dataset.image;
          document.getElementById('edit-status').value  = b.dataset.status;
        });

        // populate DELETE form
        var deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (e) {
          var b = e.relatedTarget;
          document.getElementById('delete-id').value   = b.dataset.id;
          document.getElementById('delete-name').textContent = b.dataset.name;
        });
    </script>
}
