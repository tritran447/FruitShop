@page
@model FruitShop.client.Pages.Authen.Verify_EmailModel
@{
    ViewData["Title"] = "Verify Email";
}

<!-- Page Banner Start -->
<div class="section page-banner-section">
    <div class="container-fluid custom-container">
        <div class="page-banner-wrap" style="background-image: url(/assets/images/bg/banner-bg.jpg);">
            <div class="row">
                <div class="col-lg-12">
                    <div class="page-banner text-center">
                        <h2 class="title">Verify Email</h2>
                        <ul class="breadcrumb justify-content-center">
                            <li class="breadcrumb-item"><a href="/Index">Home</a></li>
                            <li class="breadcrumb-item active">Verify Email</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Verify Email Section -->
<div class="section login-register-section section-padding-02">
    <div class="container">
        <div class="login-register-wrap mx-auto" style="max-width: 500px;">
            <div class="login-register-box">
                <div class="section-title-2 text-center">
                    <h2 class="title">Enter OTP to Verify Your Email</h2>
                </div>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert @(Model.Success ? "alert-success" : "alert-danger")">
                        @Model.Message
                    </div>
                }

                <div class="login-register-form">
                    <form method="post">
                        <div class="single-form">
                            <input asp-for="Email" class="form-control" placeholder="Email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="single-form">
                            <input asp-for="OtpCode" class="form-control" placeholder="OTP Code" />
                            <span asp-validation-for="OtpCode" class="text-danger"></span>
                        </div>
                        <div class="form-btn text-center">
                            <button type="submit" class="btn btn-secondary">Verify</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
