@page
@model FruitShop.client.Pages.Authen.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="section login-register-section section-padding-02" style="margin-top: 220px">
    <div class="container">
        <div class="login-register-wrap mx-auto" style="max-width: 450px;">
            <div class="login-register-box">
                <div class="section-title-2 text-center">
                    <h2 class="title">Forgot Password</h2>
                </div>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert @(Model.Success ? "alert-success" : "alert-danger")">
                        @Model.Message
                    </div>
                }

                <div class="login-register-form">
                    <form method="post">
                        <div class="single-form">
                            <input asp-for="Email" class="form-control" placeholder="Enter your registered email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="form-btn text-center">
                            <button type="submit" class="btn btn-secondary">Send Reset Link</button>
                        </div>

                        <div class="text-center mt-3">
                            <a asp-page="/Authen/Login_Register" class="text-decoration-underline">← Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
