<!-- Product Start -->
<div class="section argani-product-section section-padding-02">
    <div class="container">
        <div class="product-wrap">
            <div class="section-title text-center">
                <h2 class="title">Featured Products</h2>
            </div>
            <div class="product-content-wrap">
                <div class="row g-0">
                    <div class="col-xl-3">
                        <!-- Product Banner Start -->
                        <div class="product-banner text-center">
                            <div class="banner-img">
                                <img src="~/assets/images/pro-banner1.jpg" alt="">
                            </div>
                            <div class="banner-content">
                                <h3 class="sub-title">Get <span>25%</span> off</h3>
                                <h2 class="title">100% Fresh Fruits </h2>
                                <a class="btn btn-2" href="/Shop">Shop Now</a>
                            </div>
                        </div>
                        <!-- Product Banner End -->
                    </div>
                    <div class="col-xl-9">
                        <div class="product-slider-wrap">
                            <div class="swiper-container product-active">
                                <div class="swiper-wrapper">

                                    @if (popular != null && popular.Any())
                                    {
                                        @foreach (var p in popular)
                                        {
                                            <div class="swiper-slide">
                                                <div class="single-product">
                                                    <div class="product-img text-center">
                                                        <a asp-page="/Shop/Detail" asp-route-id="@p.ProductId">
                                                            <img src="~/assets/images/product-fruit/@p.Image"
                                                                 alt="@p.ProductName"
                                                                 class="img-fluid rounded-3"
                                                                 style="height: 225px; object-fit: cover;" />
                                                        </a>
                                                    </div>
                                                    <div class="product-content text-center">
                                                        <h3 class="title">
                                                            <a asp-page="/Shop/Detail" asp-route-id="@p.ProductId">
                                                                @p.ProductName
                                                            </a>
                                                        </h3>
                                                        <div class="rating"> <div class="rating-star"> <div class="rating-active" style="width: 100%;"></div> </div> </div>
                                                        <div class="price-cart d-flex justify-content-center align-items-center">
                                                            <div class="price me-3">
                                                                <span class="sale-price text-success fw-bold">
                                                                    $@p.Price
                                                                </span>
                                                            </div>
                                                            <div class="cart">
                                                                <button class="cart-icon btn btn-link p-0 position-relative"
                                                                        type="button"
                                                                        data-product-id="@p.ProductId"
                                                                        data-product-name="@p.ProductName"
                                                                        data-price="@p.Price"
                                                                        data-image-url="@p.Image">
                                                                    <i class="fas fa-shopping-basket"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="swiper-slide">
                                            <p class="text-muted">Không có sản phẩm phổ biến nào.</p>
                                        </div>
                                    }

                                </div>

                                <!-- Add Pagination / Navigation -->
                                <div class="product-arrow swiper-button-next"></div>
                                <div class="product-arrow swiper-button-prev"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- Product End -->
