@page
@model FruitShop.client.Pages.Admin.Orders.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Order Management";
}

<div class="container" style="margin-top:280px; margin-bottom: 50px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>@ViewData["Title"]</h2>
  </div>

  @if (!ModelState.IsValid)
  {
      <div class="alert alert-danger">
          <div asp-validation-summary="All"></div>
      </div>
  }

  @if (!Model.PagedOrders.Any())
  {
    <div class="alert alert-info border-0 shadow-sm rounded-3">
        <i class="fas fa-info-circle me-2"></i> No orders found.
    </div>
  }
  else
  {
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">Code</th>
                  <th>Customer</th>
                  <th>Date</th>
                  <th>Total Amount</th>
                  <th>Status</th>
                  <th class="text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var o in Model.PagedOrders)
                {
                  <tr>
                    <td class="ps-4 fw-bold">@o.OrderCode</td>
                    <td>
                        @(Model.CustomerNames.ContainsKey(o.CustomerId) ? Model.CustomerNames[o.CustomerId] : $"ID: {o.CustomerId}")
                    </td>
                    <td>@o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="fw-semibold text-success">@o.TotalAmount.ToString("C")</td>
                    <td>
                        @{
                            var badgeClass = o.Status switch
                            {
                                "Pending" => "bg-warning text-dark",
                                "Paid" => "bg-info text-dark",
                                "Processing" => "bg-primary",
                                "Delivering" => "bg-secondary",
                                "Completed" => "bg-success",
                                "Failed" => "bg-danger",
                                "Cancelled" => "bg-dark",
                                _ => "bg-light text-dark"
                            };
                        }
                        <span class="badge @badgeClass rounded-pill px-3 py-2">@o.Status</span>
                    </td>
                    <td class="text-end pe-4">
                      <button class="btn btn-sm btn-outline-primary rounded-3"
                              data-bs-toggle="modal"
                              data-bs-target="#statusModal"
                              data-id="@o.OrderId"
                              data-code="@o.OrderCode"
                              data-status="@o.Status">
                        <i class="fas fa-shipping-fast"></i> Update Status
                      </button>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
      <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-end">
          <li class="page-item @(Model.PageIndex==1? "disabled":"")">
            <a class="page-link shadow-sm"
               href="?PageIndex=@(Model.PageIndex-1)&PageSize=@Model.PageSize">
              &laquo;
            </a>
          </li>
          @for (int i = 1; i <= Model.TotalPages; i++)
          {
            <li class="page-item @(i==Model.PageIndex? "active":"")">
              <a class="page-link shadow-sm" href="?PageIndex=@i&PageSize=@Model.PageSize">@i</a>
            </li>
          }
          <li class="page-item @(Model.PageIndex==Model.TotalPages? "disabled":"")">
            <a class="page-link shadow-sm"
               href="?PageIndex=@(Model.PageIndex+1)&PageSize=@Model.PageSize">
              &raquo;
            </a>
          </li>
        </ul>
      </nav>
    }
  }

    <!-- Update Status Modal -->
    <div class="modal fade" id="statusModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <form method="post" asp-page-handler="UpdateStatus" class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Update Order Status for <span id="display-order-code" class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditOrderId" id="edit-id" />
                    <div class="mb-3">
                        <label class="form-label text-muted fw-semibold">New Status</label>
                        <select asp-for="NewStatus" class="form-select rounded-3" id="edit-status" required>
                            <option value="Pending">Pending (Chờ duyệt)</option>
                            <option value="Paid">Paid (Đã thanh toán)</option>
                            <option value="Processing">Processing (Đang xử lý)</option>
                            <option value="Delivering">Delivering (Đang giao)</option>
                            <option value="Completed">Completed (Đã giao thành công)</option>
                            <option value="Failed">Failed (Giao thất bại / Thanh toán lỗi)</option>
                            <option value="Cancelled">Cancelled (Đã hủy)</option>
                        </select>
                    </div>
                    <div class="text-muted small">
                        <i class="fas fa-info-circle text-info"></i> Note: Status changes immediately apply across the platform. Update carefully.
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4">Update Status</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var statusModal = document.getElementById('statusModal');
        statusModal.addEventListener('show.bs.modal', function (e) {
            var b = e.relatedTarget;
            document.getElementById('edit-id').value = b.dataset.id;
            document.getElementById('display-order-code').textContent = b.dataset.code;
            
            // Set current status in select dropdown securely
            var select = document.getElementById('edit-status');
            var opts = select.options;
            for (var opt, j = 0; opt = opts[j]; j++) {
                if (opt.value == b.dataset.status) {
                    select.selectedIndex = j;
                    break;
                }
            }
        });
    </script>
}
