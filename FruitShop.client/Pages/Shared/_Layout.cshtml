@using System.Text.Json
@using BusinessLogicLayer.Dtos
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Configuration


@{
    var userDataJson = HttpContextAccessor.HttpContext?
        .Session.GetString("UserData");
    CustomerDto? currentUser = null;
    if (!string.IsNullOrEmpty(userDataJson))
    {
        try
        {
            currentUser = JsonSerializer.Deserialize<CustomerDto>(userDataJson);
        }
        catch { }
    }
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FruitShop.client</title>
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="~/assets/images/favicon.png">

    <!-- CSS
    ============================================ -->
    <!-- Icon Font CSS -->
    <link rel="stylesheet" href="~/assets/css/plugins/all.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/flaticon.css">

    <!-- Plugins CSS -->
    <link rel="stylesheet" href="~/assets/css/plugins/bootstrap.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/swiper-bundle.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/aos.css">
    <link rel="stylesheet" href="~/assets/css/plugins/jquery-ui.min.css">

    <!-- Main Style CSS -->
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>
<body>
    <div class="main-wrapper">

        <!-- Preloader start -->
        <div class="theme-loader">
            <div class="spinner">
                <div class="double-bounce1"></div>
                <div class="double-bounce2"></div>
            </div>
        </div>
        <!-- Preloader end -->
        <!-- Header Start  -->
        <div class="section header-section">

            <!-- Header Top Start  -->
            <div class="header-top-section">
                <div class="container-fluid custom-container">
                    <div class="header-top-wrap">
                        <!-- Header Logo Start  -->
                        <div class="header-logo">
                            <a href="/Index"><img src="~/assets/images/logo.png" alt=""></a>
                        </div>
                        <!-- Header Logo End  -->
                        <!-- Header Search Start  -->
                        <div class="header-search d-none d-xl-block">
                            <form method="get" action="/Shop">
                                <input type="text"
                                       name="Search"
                                       value="@(Context.Request.Query["Search"].FirstOrDefault() ?? "")"
                                       placeholder="Search Products …" />
                                <button type="submit"><i class="flaticon-loupe"></i></button>
                            </form>
                        </div>
                        <!-- Header Search End  -->
                        <!-- Header Top Meta Start  -->
                        <div class="header-top-meta">
                            <!-- Header Info Start  -->
                            <div class="header-info d-none d-lg-flex">
                                <div class="info-icon">
                                    <img src="~/assets/images/info-icon2.png" alt="">
                                </div>
                                <div class="info-text">
                                    <p>Call Us Free</p>
                                    <h3 class="number">+91 458 654 528</h3>
                                </div>
                            </div>
                            <!-- Header Info End  -->
                            <!-- Header Login Start  -->
                            <div class="header-login d-none d-lg-block">
                                @if (currentUser != null)
                                {
                                    <a href="/Authen/Login_Register"><i class="far fa-user"></i></a>
                                    <a class="login" href="/Customers/Profile">Hello, @currentUser.FullName</a>
                                }
                                else
                                {
                                    <a href="/Authen/Login_Register"><i class="far fa-user"></i></a>
                                    <a class="login" href="/Authen/Login_Register">Login</a>
                                }
                            </div>
                            <!-- Header Login End  -->
                            <!-- Header Cart Start -->
                            <div class="header-cart dropdown d-none d-lg-block">
                                <a class="cart-btn-2 position-relative" href="/Cart">
                                    <i class="flaticon-shopping-bag"></i>
                                    <span id="cartCount" class="count badge rounded-pill bg-danger">0</span>
                                </a>
                            </div>
                            <!-- Header Cart End -->
                        </div>
                        <!-- Header Top Meta End  -->
                    </div>
                </div>
            </div>
            <!-- Header Top End  -->
            <!-- Header Bottom Start  -->
            <div id="header" class="header-bottom-section">
                <div class="container-fluid custom-container">

                    <!-- Header Bottom Wrap Start  -->
                    <div class="header-bottom-wrap">

                        <!-- Header Logo Start  -->
                        <div class="header-logo logo-one">
                            <a href="/Index"><img src="~/assets/images/logo-2.png" alt=""></a>
                        </div>
                        <!-- Header Logo End  -->
                        <!-- Header Category Start  -->
                        <div class="header-category dropdown d-none d-lg-block">
                            <a href="/Index"><img src="~/assets/images/logo-3.jpg" alt="" style="width: 25%;"></a>
                        </div>
                        <!-- Header Category End -->


                        <div class="header-menu d-none d-lg-block">
                            @if (currentUser?.Role?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true)
                            {
                                <ul class="main-menu">
                                    <li><a asp-page="/Admin/Dashboard/Index">Dashboard</a></li>
                                    <li><a asp-page="/Admin/Users/Index">Manage Customers</a></li>
                                    <li><a asp-page="/Admin/Products/Index">Manage Products</a></li>
                                </ul>
                            }
                            else
                            {
                                <ul class="main-menu">
                                    <li class="active-menu"><a href="/Index">Home</a></li>
                                    <li><a href="/Shop">Shop</a></li>
                                    <li><a href="/Contact">Contact</a></li>
                                </ul>
                            }
                        </div>

                        <!-- Header Meta Start -->
                        <div class="header-bottom-meta">

                            <div class="shipping-wrap d-none d-lg-flex">
                                <div class="shipping-icon">
                                    <img src="~/assets/images/shipping-icon.png" alt="">
                                </div>
                                <div class="shipping-text">
                                    <h4 class="title">Free Delivery for over $50 shopping</h4>
                                </div>
                            </div>

                        </div>
                        <!-- Header Meta End  -->


                    </div>
                    <!-- Header Bottom Wrap End  -->
                    <!-- Header Sticky Start -->
                    <div class="header-sticky">
                        <!-- Header Logo Start  -->
                        <div class="header-logo">
                            <a href="/Index"><img src="~/assets/images/logo-2.png" alt=""></a>
                        </div>
                        <!-- Header Logo End  -->
                        <!-- Header Toggle Start -->
                        <div class="header-toggle d-lg-none">
                            <button data-bs-toggle="offcanvas" data-bs-target="#offcanvasExample">
                                <span></span>
                                <span></span>
                                <span></span>
                            </button>
                        </div>
                        <!-- Header Toggle End -->
                    </div>
                    <!-- Header Sticky End -->

                </div>
            </div>
            <!-- Header Bottom End  -->

        </div>
        <!-- Header End -->
        <!-- Offcanvas Start-->
        <div class="offcanvas offcanvas-start" id="offcanvasExample">
            <div class="offcanvas-header">
                <!-- Offcanvas Logo Start -->
                <div class="offcanvas-logo">
                    <a href="/Index"><img src="~/assets/images/logo-2.png" alt=""></a>
                </div>
                <!-- Offcanvas Logo End -->
                <button type="button" class="close-btn" data-bs-dismiss="offcanvas">
                    <i class="flaticon-close"></i>
                </button>
            </div>

            <!-- Offcanvas Body Start -->
            <div class="offcanvas-body">
                <div class="offcanvas-menu">
                    <ul class="main-menu">
                        <li class="active-menu">
                            <a href="/Index">Home</a>
                        </li>
                        <li>
                            <a href="shop.html"> Shop</a>
                        </li>
                        <li><a href="contact.html">Contact</a></li>
                    </ul>
                </div>
            </div>
            <!-- Offcanvas Body End -->
        </div>
        <!-- Offcanvas End -->

        <div class="container-fluid" style="margin-top: -50px">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer Section Start -->
    <div class="section footer-section mt-5" style="background-image: url(~/assets/images/bg/footer-bg1.jpg);">

        <!-- Footer Top Start -->
        <div class="footer-top-area">
            <div class="container">
                <div class="row">
                    <div class="col-lg-3 col-sm-6">
                        <div class="footer-logo">
                            <a href="/Index"><img src="~/assets/images/logo-2.png" alt="Logo"></a>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6">
                        <div class="footer-info-item">
                            <div class="info-icon">
                                <i class="fas fa-headset"></i>
                            </div>
                            <div class="info-text">
                                <p>Call Us 24/7 Free</p>
                                <h3 class="number">+91 458 654 528</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6">
                        <div class="footer-info-item">
                            <div class="info-icon">
                                <i class="far fa-clock"></i>
                            </div>
                            <div class="info-text">
                                <p>Office Hourse</p>
                                <h3 class="number">9:00 - 18:00 </h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6">
                        <div class="footer-social">
                            <h3 class="label">Follow Us On Social</h3>
                            <ul class="social">
                                <li><a class="facebook" href="#"><i class="fab fa-facebook-f"></i></a></li>
                                <li><a class="twitter" href="#"><i class="fab fa-twitter"></i></a></li>
                                <li><a class="linkedin" href="#"><i class="fab fa-linkedin-in"></i></a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Footer Top End -->
        <!-- Footer Bottom Start -->
        <div class="footer-bottom-area">
            <div class="container">
                <!-- Footer Widget Wrap Start -->
                <div class="footer-widget-wrap">
                    <div class="row">
                        <div class="col-lg-3 col-sm-6">
                            <!-- Footer Widget Start -->
                            <div class="footer-widget">
                                <h4 class="footer-widget-title">About Us</h4>
                                <p class="about-text">
                                    Quickly supply alternative strategic theme areas vis-a-vis B2C
                                    mindshare. Objectively repurpose stand-alone synergy via user-centric
                                    architectures.
                                </p>

                            </div>
                            <!-- Footer Widget End -->
                        </div>
                        <div class="col-lg-3 col-sm-6">
                            <!-- Footer Widget Start -->
                            <div class="footer-widget footer-widget-1">
                                <h4 class="footer-widget-title">Useful Links</h4>

                                <div class="widget-link">
                                    <ul class="link">
                                        <li><a href="#">Terms & Conditions</a></li>
                                        <li><a href="#">About Company</a></li>
                                        <li><a href="#">Payment Gatway</a></li>
                                        <li><a href="#">Policy</a></li>
                                        <li><a href="#">Return & Refund</a></li>
                                    </ul>
                                </div>
                            </div>
                            <!-- Footer Widget End -->
                        </div>
                        <div class="col-lg-3 col-sm-6">
                            <!-- Footer Widget Start -->
                            <div class="footer-widget footer-widget-2">
                                <h4 class="footer-widget-title">Our Services</h4>

                                <div class="widget-link">
                                    <ul class="link">
                                        <li><a href="#">Data Security</a></li>
                                        <li><a href="#">IT Managment</a></li>
                                        <li><a href="#">Outsourcing</a></li>
                                        <li><a href="#">Networking</a></li>
                                        <li><a href="#">Contact Us</a></li>
                                    </ul>
                                </div>
                            </div>
                            <!-- Footer Widget End -->
                        </div>
                        <div class="col-lg-3 col-sm-6">
                            <!-- Footer Widget Start -->
                            <div class="footer-widget">
                                <h4 class="footer-widget-title">Sign Up for Our Newsletter</h4>

                                <p class="text">
                                    Leave your email to get all hot deals & news which benefit you most!
                                </p>
                                <div class="widget-search">
                                    <form action="#">
                                        <input type="text" placeholder="Your Email">
                                        <button type="submit"><i class="flaticon-send"></i></button>
                                    </form>
                                </div>
                            </div>
                            <!-- Footer Widget End -->
                        </div>
                    </div>
                </div>
                <!-- Footer Widget Wrap End -->
            </div>
        </div>
        <!-- Footer Bottom End -->
        <!-- Footer Copyright Start -->
        <div class="footer-copyright-area">
            <div class="container">
                <div class="footer-copyright-wrap">
                    <div class="row align-items-center">
                        <div class="col-lg-6">
                            <!-- Footer Copyright Text Start -->
                            <div class="copyright-text">
                                <p>© 2024 Argani. All Rights Reserved </p>
                            </div>
                            <!-- Footer Copyright Text End -->
                        </div>
                        <div class="col-lg-6">
                            <!-- Footer Payment Start -->
                            <div class="footer-payment">
                                <span class="label">We Accept Payments</span>
                                <img src="~/assets/images/pay-img.png" alt="">
                            </div>
                            <!-- Footer Payment End -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Footer Copyright End -->
    </div>
    <!-- Footer Section End -->
    <!-- back to top start -->
    <div class="progress-wrap">
        <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
            <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
        </svg>
    </div>
    <!-- back to top end -->
    <!-- JS
     ============================================ -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/assets/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="~/assets/js/vendor/modernizr-3.11.2.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="~/assets/js/plugins/popper.min.js"></script>
    <script src="~/assets/js/plugins/bootstrap.min.js"></script>

    <!-- Plugins JS -->
    <script src="~/assets/js/plugins/swiper-bundle.min.js"></script>
    <script src="~/assets/js/plugins/waypoints.min.js"></script>
    <script src="~/assets/js/plugins/jquery.counterup.min.js"></script>
    <script src="~/assets/js/plugins/aos.js"></script>
    <script src="~/assets/js/plugins/jquery-ui.min.js"></script>
    <script src="~/assets/js/plugins/back-to-top.js"></script>


    <!-- Main JS -->
    <script src="~/assets/js/main.js"></script>
    <script src="~/js/cart.js"></script>

    <script>
        window.isAuthenticated = @(
          !string.IsNullOrEmpty(HttpContextAccessor.HttpContext.Session.GetString("JwtToken"))
              ? "true"
              : "false"
                );
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>